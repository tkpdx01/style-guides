{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://style-guides.local/schemas/style-manifest.schema.json",
  "title": "Style guide manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "status",
    "summary",
    "description",
    "preview",
    "files",
    "tags",
    "traits",
    "bestFor",
    "avoidFor",
    "compatibleWith",
    "fonts"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated"]
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 320 },
    "preview": { "type": "string", "pattern": "^\\./" },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guide", "prompt", "theme"],
      "properties": {
        "guide": { "type": "string", "pattern": "^\\./" },
        "prompt": { "type": "string", "pattern": "^\\./" },
        "theme": { "type": "string", "pattern": "^\\./" }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    },
    "traits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["density", "contrast", "energy", "shape", "motion"],
      "properties": {
        "density": { "enum": ["compact", "balanced", "relaxed"] },
        "contrast": { "enum": ["low", "medium", "high"] },
        "energy": { "enum": ["quiet", "balanced", "bold"] },
        "shape": { "enum": ["sharp", "balanced", "rounded"] },
        "motion": { "enum": ["minimal", "subtle", "expressive"] }
      }
    },
    "bestFor": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "avoidFor": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "compatibleWith": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "fonts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "family", "fallback"],
        "properties": {
          "role": { "enum": ["sans", "serif", "mono", "display"] },
          "family": { "type": "string", "minLength": 1 },
          "fallback": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
