{
  "$schema": "../../schemas/style-manifest.schema.json",
  "id": "precision-ui",
  "name": "Precision UI",
  "version": "1.0.0",
  "status": "ready",
  "summary": "Compact application pages with crisp type, one-pixel structure, sharp geometry, and restrained cobalt accents.",
  "description": "A professional interface system for SaaS, enterprise portals, developer tools, and operational products. It applies Precision Grid's typography and density discipline to general navigation, dashboards, lists, forms, and settings without spreadsheet chrome.",
  "preview": "./assets/preview.png",
  "files": {
    "guide": "./README.md",
    "prompt": "./PROMPT.md",
    "theme": "./theme.css",
    "demo": "./demo/index.html"
  },
  "tags": [
    "app-shell",
    "compact",
    "enterprise",
    "professional",
    "sharp",
    "structured"
  ],
  "traits": {
    "density": "compact",
    "contrast": "medium",
    "energy": "quiet",
    "shape": "sharp",
    "motion": "minimal"
  },
  "bestFor": [
    "SaaS application interfaces",
    "Enterprise portals and internal tools",
    "Developer and infrastructure products",
    "Operational dashboards and settings"
  ],
  "avoidFor": [
    "Brand-led marketing experiences",
    "Touch-first consumer applications",
    "Long-form editorial reading",
    "Playful products that depend on expressive illustration"
  ],
  "compatibleWith": [
    "Plain CSS",
    "React",
    "Next.js",
    "Vue",
    "Tailwind CSS"
  ],
  "fonts": [
    {
      "role": "sans",
      "family": "Segoe UI Variable",
      "fallback": "Segoe UI, Inter, system-ui, sans-serif"
    },
    {
      "role": "mono",
      "family": "Cascadia Mono",
      "fallback": "Consolas, ui-monospace, monospace"
    }
  ]
}
